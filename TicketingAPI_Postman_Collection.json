{
  "info": {
    "name": "Incident Ticketing API",
    "description": "API collection for managing IT Incident Tickets including endpoints for creating tickets (with attachments), retrieving tickets, updating statuses, and verifying comment deletions.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Create Ticket (Form-Data)",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "ticket",
              "value": "{\n  \"category\": \"Hardware\",\n  \"description\": \"My laptop screen is completely black when I turn it on.\",\n  \"priority\": \"High\",\n  \"resourceLocation\": \"Office 402, Desk 4\",\n  \"contactDetails\": \"john.doe@example.com\"\n}",
              "type": "text",
              "contentType": "application/json"
            },
            {
              "key": "files",
              "type": "file",
              "src": [],
              "description": "Attach up to 3 image files."
            }
          ]
        },
        "url": {
          "raw": "http://localhost:8080/api/tickets",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "tickets"
          ]
        }
      }
    },
    {
      "name": "2. Get All Tickets (Filterable)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/tickets?status=OPEN",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "tickets"
          ],
          "query": [
            {
              "key": "status",
              "value": "OPEN",
              "description": "Optional status filter (e.g. OPEN, IN_PROGRESS, RESOLVED)",
              "disabled": false
            }
          ]
        }
      }
    },
    {
      "name": "3. Technician: Update Ticket Status",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"status\": \"IN_PROGRESS\",\n  \"resolutionNotes\": \"Currently waiting for replacement parts to arrive.\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:8080/api/tickets/1",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "tickets",
            "1"
          ]
        }
      }
    },
    {
      "name": "4. Delete Comment",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "X-User-Id",
            "value": "1",
            "type": "text",
            "description": "The ID of the user triggering the deletion to verify ownership."
          }
        ],
        "url": {
          "raw": "http://localhost:8080/api/tickets/1/comments/1",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "api",
            "tickets",
            "1",
            "comments",
            "1"
          ]
        }
      }
    }
  ]
}
